{
  "name": "@fatal-cinema/contracts",
  "version": "1.1.2",
  "description": "Protobuf definitions and generated TypeScript types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "rimraf ./dist",
    "generate": "protoc -I ./proto --ts_proto_out=./gen --ts_proto_opt=nestJs=true,package=omit ./proto/auth/v1/*.proto",
    "pregenerate": "rimraf ./gen && mkdirp ./gen"
  },
  "files": [
    "proto",
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./gen/auth": {
      "import": "./dist/gen/auth/v1/auth.js",
      "types": "./dist/gen/auth/v1/auth.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "fatal-zxc",
    "email": "faaatal_l@proton.me"
  },
  "license": "ISC",
  "dependencies": {
    "@nestjs/microservices": "^11.1.19",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.3",
    "ts-proto": "^2.11.6",
    "typescript": "^6.0.3"
  }
}
